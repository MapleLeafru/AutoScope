<Window x:Class="AutoScope.WpfClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:AutoScope.WpfClient.Converters"
        Title="AutoScope" Height="780" Width="1280" MinHeight="680" MinWidth="1050"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Window.Resources>
        <conv:StatusToBrushConverter x:Key="StatusToBrushConverter"/>
    </Window.Resources>

    <Grid Margin="22" Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="18" Padding="22" Margin="0,0,0,7">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="AutoScope" FontSize="30" FontWeight="SemiBold"/>
                    <TextBlock Text="Центр наблюдения и управления автомобильными данными" Style="{StaticResource SecondaryText}" Margin="0,4,0,0"/>
                    <TextBlock Text="{Binding RootPathText}" Style="{StaticResource MutedText}" Margin="0,12,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <Button Content="Обновить" Style="{StaticResource AccentButton}" Click="Refresh_Click"/>
                    <Button Content="Открыть папку проекта" Style="{StaticResource BaseButton}" Click="OpenRootFolder_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Быстрые действия -->
            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource HubCard}">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="Быстрые действия" Style="{StaticResource CardTitle}"/>
                        <TextBlock Text="Главные команды без захода в подробные разделы." Style="{StaticResource SectionCaption}"/>
                    </StackPanel>

                    <WrapPanel>
                        <Button Content="Запустить парсинг" Style="{StaticResource AccentButton}" Click="Stub_Click" Tag="Запуск парсинга из UI будет подключён следующим шагом через RunManagerService."/>
                        <Button Content="Сформировать отчёт" Style="{StaticResource AccentButton}" Click="Stub_Click" Tag="Запуск анализатора из UI будет подключён следующим шагом через RunManagerService."/>
                        <Button Content="Открыть папку отчётов" Style="{StaticResource BaseButton}" Click="OpenReportsFolder_Click"/>
                        <Button Content="Открыть папку логов" Style="{StaticResource BaseButton}" Click="OpenLogsFolder_Click"/>
                        <Button Content="Настройки" Style="{StaticResource BaseButton}" Click="Stub_Click" Tag="Экран настроек будет добавлен после проверки главного хаба."/>
                    </WrapPanel>
                </DockPanel>
            </Border>

            <!-- Сценарии -->
            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource HubCard}">
                <DockPanel LastChildFill="True">
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Сценарии" Style="{StaticResource CardTitle}"/>
                            <TextBlock Text="Активные, ручные и выключенные сценарии." Style="{StaticResource SectionCaption}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Управление" Style="{StaticResource SmallButton}" Click="Stub_Click" Tag="Подробный экран сценариев будет следующим отдельным экраном."/>
                    </Grid>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Scenarios}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ListRow}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="6" CornerRadius="3" Background="{Binding StateKind, Converter={StaticResource StatusToBrushConverter}}"/>
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding StatusText}" Foreground="{Binding StateKind, Converter={StaticResource StatusToBrushConverter}}" FontSize="12" Margin="0,2,0,0"/>
                                                <TextBlock Text="{Binding Details}" Style="{StaticResource MutedText}" Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Базы данных -->
            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource HubCard}">
                <DockPanel LastChildFill="True">
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Базы данных" Style="{StaticResource CardTitle}"/>
                            <TextBlock Text="Последние найденные SQLite-базы в проекте." Style="{StaticResource SectionCaption}"/>
                        </StackPanel>
                        <WrapPanel Grid.Column="1">
                            <Button Content="Папка" Style="{StaticResource SmallButton}" Click="OpenRootFolder_Click"/>
                            <Button Content="Управление" Style="{StaticResource SmallButton}" Click="Stub_Click" Tag="Подробное управление базами добавим после проверки хаба."/>
                        </WrapPanel>
                    </Grid>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Databases}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ListRow}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding RecordsText}" Foreground="{DynamicResource AccentBrush}" FontSize="12" Margin="0,2,0,0"/>
                                                <TextBlock Text="{Binding Details}" Style="{StaticResource MutedText}" Margin="0,3,0,0"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                                <Button Content="DB Browser" Style="{StaticResource SmallButton}" Click="OpenDbBrowser_Click" Tag="{Binding}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Процессы -->
            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource HubCard}">
                <DockPanel LastChildFill="True">
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Процессы" Style="{StaticResource CardTitle}"/>
                            <TextBlock Text="Активная работа, завершения и ошибки текущей UI-сессии." Style="{StaticResource SectionCaption}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Менеджер" Style="{StaticResource SmallButton}" Click="Stub_Click" Tag="Подробный менеджер процессов будет подключён к RunManagerService следующим шагом."/>
                    </Grid>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Processes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ListRow}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="6" CornerRadius="3" Background="{Binding StateKind, Converter={StaticResource StatusToBrushConverter}}"/>
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding StatusText}" Foreground="{Binding StateKind, Converter={StaticResource StatusToBrushConverter}}" FontSize="12" Margin="0,2,0,0"/>
                                                <TextBlock Text="{Binding Details}" Style="{StaticResource MutedText}" Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Style="{StaticResource MutedText}" Margin="4,10,0,0"/>
    </Grid>
</Window>
