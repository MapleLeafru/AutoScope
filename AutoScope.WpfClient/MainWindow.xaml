<Window x:Class="AutoScope.WpfClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:AutoScope.WpfClient.Converters"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="AutoScope" Height="780" Width="1280" MinHeight="680" MinWidth="1050"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="Transparent"
        AllowsTransparency="True"
        UseLayoutRounding="True">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <conv:StatusToBrushConverter x:Key="StatusToBrushConverter"/>
    </Window.Resources>

    <Border x:Name="RootWindowBorder"
            Background="{DynamicResource WindowOutlineBrush}"
            CornerRadius="12"
            SnapsToDevicePixels="True">
        <Border Background="{DynamicResource WindowBackgroundBrush}"
                CornerRadius="11"
                Margin="1"
                SnapsToDevicePixels="True">
            <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border x:Name="TitleBar"
                Grid.Row="0"
                Background="{DynamicResource TitleBarBackgroundBrush}"
                BorderBrush="{DynamicResource TitleBarBorderBrush}"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                CornerRadius="11,11,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                    <Grid Width="24" Height="24" Margin="0,0,9,0">
                        <Ellipse Width="19" Height="19"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Top"
                                 Fill="{DynamicResource AccentButtonBackgroundBrush}"
                                 Stroke="{DynamicResource AccentBrush}"
                                 StrokeThickness="1.4"/>
                        <Line X1="15.5" Y1="15.5" X2="21.5" Y2="21.5"
                              Stroke="{DynamicResource AccentBrush}"
                              StrokeThickness="2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"/>
                        <TextBlock Text="A"
                                   Width="19"
                                   Height="19"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Top"
                                   FontWeight="SemiBold"
                                   FontSize="11"
                                   TextAlignment="Center"
                                   Padding="0,1,0,0"/>
                    </Grid>
                    <TextBlock Text="AutoScope" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,2,6,2">
                    <Button Style="{StaticResource TitleBarButton}" Click="Minimize_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Viewbox Width="14" Height="14" Stretch="Uniform">
                            <Canvas Width="18" Height="18">
                                <Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M 3 9 L 15 9"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                    <Button Style="{StaticResource TitleBarButton}" Click="MaximizeRestore_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Viewbox Width="14" Height="14" Stretch="Uniform">
                            <Rectangle Width="11" Height="11" Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.5" RadiusX="1" RadiusY="1"/>
                        </Viewbox>
                    </Button>
                    <Button Style="{StaticResource TitleBarCloseButton}" Click="Close_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Viewbox Width="19" Height="19" Stretch="Uniform">
                            <Canvas Width="18" Height="18">
                                <Path Stroke="{DynamicResource TextPrimaryBrush}"
                                      StrokeThickness="2.0"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Data="M 4 4 L 14 14 M 14 4 L 4 14"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="22" Background="{DynamicResource WindowBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Быстрые действия -->
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource HubCard}">
                    <DockPanel LastChildFill="True">
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="AutoScope"
                                       FontSize="30"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="1"
                                       Grid.ColumnSpan="2"
                                       Text="Центр наблюдения и управления данными"
                                       Style="{StaticResource SecondaryText}"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap"/>

                            <TextBlock Grid.Row="2"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding RootPathText}"
                                       Style="{StaticResource MutedText}"
                                       Margin="0,5,0,0"
                                       TextTrimming="CharacterEllipsis"/>
                        </Grid>

                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                            <TextBlock Text="Быстрые действия" Style="{StaticResource CardTitle}"/>
                            <TextBlock Text="Главные команды без захода в подробные разделы." Style="{StaticResource SectionCaption}"/>
                        </StackPanel>

                        <WrapPanel>
                            <Button Content="Обновить" Style="{StaticResource AccentButton}" Click="Refresh_Click"/>
                            <Button Content="Запустить парсинг" Style="{StaticResource AccentButton}" Click="LaunchInputPipeline_Click"/>
                            <Button Content="Сформировать отчёт" Style="{StaticResource AccentButton}" Click="LaunchOutputPipeline_Click"/>
                            <Button Content="Отчёты" Style="{StaticResource BaseButton}" Click="OpenReportsManager_Click"/>
                            <Button Content="Открыть папку проекта" Style="{StaticResource BaseButton}" Click="OpenRootFolder_Click"/>
                            <Button Content="Открыть папку логов" Style="{StaticResource BaseButton}" Click="OpenLogsFolder_Click"/>
                            <Button Content="Настройки" Style="{StaticResource BaseButton}" Click="Settings_Click"/>
                        </WrapPanel>
                    </DockPanel>
                </Border>

                <!-- Сценарии -->
                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource HubCard}">
                    <DockPanel LastChildFill="True">
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Сценарии" Style="{StaticResource CardTitle}"/>
                                <TextBlock Text="Активные, ручные и выключенные сценарии." Style="{StaticResource SectionCaption}"/>
                            </StackPanel>
                            <WrapPanel Grid.Column="1" VerticalAlignment="Top">
                                <Button Content="Папка" Style="{StaticResource SmallButton}" Click="OpenJobsFolder_Click"/>
                                <Button Content="Управление" Style="{StaticResource SmallButton}" Click="OpenScenarioManager_Click"/>
                            </WrapPanel>
                        </Grid>

                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Scenarios}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource ListRow}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="10"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Width="6" CornerRadius="3" Background="{Binding StateKind, Converter={StaticResource StatusToBrushConverter}}"/>
                                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding StatusText}" Foreground="{Binding StateKind, Converter={StaticResource StatusToBrushConverter}}" FontSize="12" Margin="0,2,0,0"/>
                                                    <TextBlock Text="{Binding Details}" Style="{StaticResource MutedText}" Margin="0,3,0,0"/>
                                                </StackPanel>
                                                <Button Grid.Column="2"
                                                        Content="Запуск"
                                                        Tag="{Binding}"
                                                        Click="StartScenarioFromHub_Click"
                                                        VerticalAlignment="Top"
                                                        Margin="10,0,0,0">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource AccentSmallButton}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding CanRun}" Value="False">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- Базы данных -->
                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource HubCard}">
                    <DockPanel LastChildFill="True">
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Базы данных" Style="{StaticResource CardTitle}"/>
                                <TextBlock Text="Последние найденные SQLite-базы в проекте." Style="{StaticResource SectionCaption}"/>
                            </StackPanel>
                            <WrapPanel Grid.Column="1">
                                <Button Content="Папка" Style="{StaticResource SmallButton}" Click="OpenDatabasesFolder_Click"/>
                                <Button Content="Управление" Style="{StaticResource SmallButton}" Click="OpenDatabaseManager_Click"/>
                            </WrapPanel>
                        </Grid>

                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Databases}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource ListRow}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                    <WrapPanel Margin="0,2,0,0">
                                                        <TextBlock Text="{Binding RecordsText}" Foreground="{DynamicResource AccentBrush}" FontSize="12" FontWeight="SemiBold"/>
                                                        <TextBlock Text=" · " Style="{StaticResource MutedText}"/>
                                                        <TextBlock Text="{Binding SizeText}" Foreground="{DynamicResource AccentBrush}" FontSize="12" FontWeight="SemiBold"/>
                                                    </WrapPanel>
                                                    <TextBlock Text="{Binding Details}" Style="{StaticResource MutedText}" Margin="0,3,0,0"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                                    <Button Content="DB Browser" Style="{StaticResource SmallButton}" Click="OpenDbBrowser_Click" Tag="{Binding}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- Процессы -->
                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource HubCard}">
                    <DockPanel LastChildFill="True">
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Процессы" Style="{StaticResource CardTitle}"/>
                                <TextBlock Text="Активные процессы сверху, история подгружается отдельно." Style="{StaticResource SectionCaption}"/>
                            </StackPanel>
                            <WrapPanel Grid.Column="1" VerticalAlignment="Top">
                                <Button Content="Управление" Style="{StaticResource SmallButton}" Click="Stub_Click" Tag="Подробный менеджер процессов будет выполнен в карточном стиле: расширенный список процессов, фильтры, логи и действия."/>
                            </WrapPanel>
                        </Grid>

                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Processes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Border x:Name="ProcessContent" Style="{StaticResource ProcessCard}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="10"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Border Width="6" CornerRadius="3" Background="{Binding StateKind, Converter={StaticResource StatusToBrushConverter}}"/>

                                                    <StackPanel Grid.Column="1" Margin="10,0,10,0">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding TimeText}" Style="{StaticResource MutedText}" Margin="12,1,0,0"/>
                                                        </Grid>

                                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                            <TextBlock Text="{Binding StatusText}" Foreground="{Binding StateKind, Converter={StaticResource StatusToBrushConverter}}" FontSize="12" FontWeight="SemiBold"/>
                                                            <TextBlock Text=" · " Style="{StaticResource MutedText}"/>
                                                            <TextBlock Text="{Binding TypeText}" Style="{StaticResource MutedText}"/>
                                                        </StackPanel>

                                                        <StackPanel x:Name="ProgressArea" Margin="0,7,0,0">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Text="{Binding StageText}" Style="{StaticResource MutedText}"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding ProgressText}" Foreground="{Binding StateKind, Converter={StaticResource StatusToBrushConverter}}" FontSize="12" FontWeight="SemiBold"/>
                                                            </Grid>
                                                            <ProgressBar Style="{StaticResource ProcessProgressBar}" Value="{Binding ProgressPercent}" Foreground="{Binding StateKind, Converter={StaticResource StatusToBrushConverter}}" Margin="0,5,0,0"/>
                                                            <TextBlock Text="{Binding CountText}" Style="{StaticResource MutedText}" Margin="0,4,0,0"/>
                                                        </StackPanel>

                                                        <TextBlock Text="{Binding Details}" Style="{StaticResource MutedText}" Margin="0,7,0,0" TextWrapping="Wrap"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                                                        <Button x:Name="PauseProcessButton" Content="Пауза" Style="{StaticResource SmallButton}" Click="PauseProcess_Click" Tag="{Binding}" IsEnabled="{Binding CanPause}" Visibility="Collapsed"/>
                                                        <Button x:Name="ResumeProcessButton" Content="Продолжить" Style="{StaticResource AccentSmallButton}" Click="ResumeProcess_Click" Tag="{Binding}" IsEnabled="{Binding CanResume}" Visibility="Collapsed"/>
                                                        <Button x:Name="StopProcessButton" Content="Стоп" Style="{StaticResource DangerSmallButton}" Click="StopProcess_Click" Tag="{Binding}" IsEnabled="{Binding CanStop}" Visibility="Collapsed"/>
                                                        <Button Content="Лог" Style="{StaticResource SmallButton}" Click="OpenProcessLog_Click" Tag="{Binding}" IsEnabled="{Binding CanOpenLog}"/>
                                                        <Button Content="Открыть" Style="{StaticResource SmallButton}" Click="ShowProcessInfo_Click" Tag="{Binding}" IsEnabled="{Binding CanOpenDetails}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <Border x:Name="HistoryActionPanel" Style="{StaticResource ProcessHistoryActionCard}" Visibility="Collapsed">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding ActionHint}" Style="{StaticResource MutedText}" Margin="0,0,0,8" TextWrapping="Wrap"/>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="2*"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Button Content="{Binding PrimaryActionText}" Style="{StaticResource SmallButton}" Click="LoadProcessHistory_Click" Tag="{Binding}" IsEnabled="{Binding IsPrimaryActionEnabled}" HorizontalAlignment="Stretch" Margin="0,0,6,0"/>
                                                        <Button x:Name="LoadAllHistoryButton" Grid.Column="1" Content="{Binding SecondaryActionText}" Style="{StaticResource SmallButton}" Click="LoadAllProcessHistory_Click" Tag="{Binding}" HorizontalAlignment="Stretch" Margin="0" Visibility="Collapsed"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsProgressVisible}" Value="False">
                                                <Setter TargetName="ProgressArea" Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsActionRow}" Value="True">
                                                <Setter TargetName="ProcessContent" Property="Visibility" Value="Collapsed"/>
                                                <Setter TargetName="HistoryActionPanel" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsSecondaryActionVisible}" Value="True">
                                                <Setter TargetName="LoadAllHistoryButton" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding CanPause}" Value="True">
                                                <Setter TargetName="PauseProcessButton" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding CanResume}" Value="True">
                                                <Setter TargetName="ResumeProcessButton" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding CanStop}" Value="True">
                                                <Setter TargetName="StopProcessButton" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="1" Margin="4,10,4,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource MutedText}"/>
                <TextBlock Grid.Column="1" Text="{Binding AppVersionText}" Style="{StaticResource MutedText}" HorizontalAlignment="Right"/>
            </Grid>
        </Grid>
            </Grid>
        </Border>
    </Border>
</Window>
