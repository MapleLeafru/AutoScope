<Window x:Class="AutoScope.WpfClient.ScenarioEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Редактирование сценария" Height="500" Width="620"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="Transparent"
        AllowsTransparency="True"
        UseLayoutRounding="True">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"/>
    </shell:WindowChrome.WindowChrome>

    <Border Background="{DynamicResource WindowOutlineBrush}"
            CornerRadius="12"
            SnapsToDevicePixels="True">
        <Border Background="{DynamicResource WindowBackgroundBrush}"
                CornerRadius="11"
                Margin="1"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="38"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border x:Name="TitleBar"
                        Grid.Row="0"
                        Background="{DynamicResource TitleBarBackgroundBrush}"
                        BorderBrush="{DynamicResource TitleBarBorderBrush}"
                        BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                        CornerRadius="11,11,0,0">
                    <Grid>
                        <TextBlock Text="Редактирование сценария"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="14,0,0,0"/>
                        <Button HorizontalAlignment="Right"
                                Style="{StaticResource TitleBarCloseButton}"
                                Click="Close_Click"
                                Margin="0,2,6,2"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <Viewbox Width="19" Height="19" Stretch="Uniform">
                                <Canvas Width="18" Height="18">
                                    <Path Stroke="{DynamicResource TextPrimaryBrush}"
                                          StrokeThickness="2.0"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Data="M 4 4 L 14 14 M 14 4 L 4 14"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource HubCard}" Margin="18">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Основные параметры" Style="{StaticResource CardTitle}"/>
                            <TextBlock Text="На этом шаге редактируются безопасные поля сценария: название, включение и расписание. Смена базы и модуля будет добавлена позже отдельной формой." Style="{StaticResource SectionCaption}" Margin="0,0,0,14"/>

                            <TextBlock Text="Название сценария" Style="{StaticResource SectionCaption}"/>
                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource SettingsTextBox}"
                                     Margin="0,4,0,12"/>

                            <CheckBox Content="Сценарий включён"
                                      IsChecked="{Binding Enabled}"
                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                      Margin="0,0,0,10"/>

                            <CheckBox Content="Только ручной запуск"
                                      IsChecked="{Binding IsManualOnly}"
                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                      Margin="0,0,0,12"/>

                            <TextBlock Text="Интервал автоповтора, часов" Style="{StaticResource SectionCaption}"/>
                            <TextBox Text="{Binding EveryHoursText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource SettingsTextBox}"
                                     Margin="0,4,0,14"/>

                            <Border Style="{StaticResource ListRow}">
                                <StackPanel>
                                    <TextBlock Text="Текущая связка сценария" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding PipelineText}" Style="{StaticResource MutedText}" Margin="0,4,0,0"/>
                                    <TextBlock Text="{Binding DatabaseName}" Style="{StaticResource MutedText}" Margin="0,3,0,0"/>
                                    <TextBlock Text="{Binding ModuleName}" Style="{StaticResource MutedText}" Margin="0,3,0,0"/>
                                    <TextBlock Text="{Binding FileName}" Style="{StaticResource MutedText}" Margin="0,3,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <Grid Grid.Row="2" Margin="18,0,18,18">
                    <TextBlock Text="{Binding StatusMessage}"
                               Style="{StaticResource MutedText}"
                               VerticalAlignment="Center"/>
                    <WrapPanel HorizontalAlignment="Right">
                        <Button Content="Сохранить" Style="{StaticResource AccentButton}" Click="Save_Click"/>
                        <Button Content="Отмена" Style="{StaticResource BaseButton}" Click="Cancel_Click"/>
                    </WrapPanel>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>
