<Window x:Class="AutoScope.WpfClient.ReportManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Отчёты AutoScope" Height="640" Width="880"
        MinHeight="520" MinWidth="760"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="Transparent"
        AllowsTransparency="True"
        UseLayoutRounding="True">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"/>
    </shell:WindowChrome.WindowChrome>

    <Border x:Name="RootWindowBorder"
            Background="{DynamicResource WindowOutlineBrush}"
            CornerRadius="12"
            SnapsToDevicePixels="True">
        <Border Background="{DynamicResource WindowBackgroundBrush}"
                CornerRadius="11"
                Margin="1"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="38"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border x:Name="TitleBar"
                        Grid.Row="0"
                        Background="{DynamicResource TitleBarBackgroundBrush}"
                        BorderBrush="{DynamicResource TitleBarBorderBrush}"
                        BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                        CornerRadius="11,11,0,0">
                    <Grid>
                        <TextBlock Text="Отчёты AutoScope"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="14,0,0,0"/>
                        <Button HorizontalAlignment="Right"
                                Style="{StaticResource TitleBarCloseButton}"
                                Click="Close_Click"
                                Margin="0,2,6,2"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <Viewbox Width="19" Height="19" Stretch="Uniform">
                                <Canvas Width="18" Height="18">
                                    <Path Stroke="{DynamicResource TextPrimaryBrush}"
                                          StrokeThickness="2.0"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Data="M 4 4 L 14 14 M 14 4 L 4 14"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource HubCard}" Margin="18,18,18,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Найденные отчёты" Style="{StaticResource CardTitle}"/>
                            <TextBlock Text="HTML-отчёты из папки Reports. Последние отчёты отображаются сверху." Style="{StaticResource SectionCaption}"/>
                            <TextBlock Text="{Binding ReportsFolderText}" Style="{StaticResource MutedText}"/>
                        </StackPanel>

                        <WrapPanel Grid.Column="1" VerticalAlignment="Top">
                            <Button Content="Обновить" Style="{StaticResource SmallButton}" Click="Refresh_Click"/>
                            <Button Content="Папка" Style="{StaticResource SmallButton}" Click="OpenReportsFolder_Click"/>
                        </WrapPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource HubCard}" Margin="18,0,18,10">
                    <DockPanel LastChildFill="True">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Reports}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource ListRow}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="16"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip="{Binding FileName}"/>
                                                    <TextBlock Text="{Binding AnalyzerText}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               FontSize="12"
                                                               Margin="0,2,0,0"/>
                                                    <WrapPanel Margin="0,3,0,0">
                                                        <TextBlock Text="{Binding DateText}"
                                                                   Foreground="{DynamicResource AccentBrush}"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"/>
                                                        <TextBlock Text=" · " Style="{StaticResource MutedText}"/>
                                                        <TextBlock Text="{Binding SizeText}"
                                                                   Foreground="{DynamicResource AccentBrush}"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"/>
                                                    </WrapPanel>
                                                    <TextBlock Text="{Binding FileName}" Style="{StaticResource MutedText}" Margin="0,3,0,0"/>
                                                </StackPanel>

                                                <WrapPanel Grid.Column="1" VerticalAlignment="Top" Margin="12,0,0,0">
                                                    <Button Content="Открыть" Style="{StaticResource AccentSmallButton}" Click="OpenReport_Click" Tag="{Binding}" IsEnabled="{Binding CanOpen}"/>
                                                    <Button Content="Папка" Style="{StaticResource SmallButton}" Click="OpenReportFolder_Click" Tag="{Binding}" IsEnabled="{Binding CanOpen}"/>
                                                    <Button Content="Удалить" Style="{StaticResource DangerSmallButton}" Click="DeleteReport_Click" Tag="{Binding}" IsEnabled="{Binding CanOpen}"/>
                                                </WrapPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <Grid Grid.Row="3" Margin="18,0,18,18">
                    <TextBlock Text="{Binding StatusMessage}"
                               Style="{StaticResource MutedText}"
                               VerticalAlignment="Center"/>
                    <Button Content="Закрыть"
                            Style="{StaticResource BaseButton}"
                            HorizontalAlignment="Right"
                            Click="Close_Click"/>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>
