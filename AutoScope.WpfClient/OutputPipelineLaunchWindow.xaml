<Window x:Class="AutoScope.WpfClient.OutputPipelineLaunchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:AutoScope.WpfClient.Models"
        Title="Формирование отчёта" Height="650" Width="780"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinHeight="590" MinWidth="700"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}">
    <Window.Resources>
        <DataTemplate x:Key="DatabaseComboItemTemplate" DataType="{x:Type models:DatabaseDashboardItem}">
            <StackPanel>
                <TextBlock Text="{Binding Name}"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontWeight="SemiBold"/>
                <TextBlock Text="{Binding ConfigText}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="11"
                           Margin="0,2,0,0"/>
                <TextBlock Text="{Binding FileText}"
                           Foreground="{DynamicResource TextMutedBrush}"
                           FontSize="11"
                           Margin="0,1,0,0"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="AnalyzerComboItemTemplate" DataType="{x:Type models:AnalyzerLaunchItem}">
            <StackPanel>
                <TextBlock Text="{Binding DisplayName}"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontWeight="SemiBold"/>
                <TextBlock Text="{Binding FileName}"
                           Foreground="{DynamicResource TextMutedBrush}"
                           FontSize="11"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Border Margin="18" Style="{StaticResource HubCard}">
        <DockPanel LastChildFill="True">
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                <TextBlock Text="Формирование отчёта" Style="{StaticResource CardTitle}"/>
                <TextBlock Text="Выбери базу, анализатор и фильтры выборки. Отчёт будет сформирован через OutputPipeline и сохранён в папку Reports." Style="{StaticResource SectionCaption}"/>
            </StackPanel>

            <StackPanel DockPanel.Dock="Bottom" Margin="0,16,0,0">
                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource MutedText}" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="После запуска обнови хаб общей кнопкой. Завершённый процесс и отчёт можно будет найти через блок процессов и папку отчётов." Style="{StaticResource MutedText}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Отмена" Style="{StaticResource BaseButton}" Click="Cancel_Click" Margin="8,0,8,0"/>
                    <Button Grid.Column="2" Content="Сформировать" Style="{StaticResource AccentButton}" Click="Start_Click" Margin="0"/>
                </Grid>
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="База данных" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding Databases}"
                              SelectedItem="{Binding SelectedDatabase}"
                              ItemTemplate="{StaticResource DatabaseComboItemTemplate}"
                              Style="{StaticResource SettingsComboBox}"
                              Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding SelectedDatabase.Details}" Style="{StaticResource MutedText}" Margin="0,0,0,16"/>

                    <TextBlock Text="Анализатор" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding Analyzers}"
                              SelectedItem="{Binding SelectedAnalyzer}"
                              ItemTemplate="{StaticResource AnalyzerComboItemTemplate}"
                              Style="{StaticResource SettingsComboBox}"
                              SelectionChanged="AnalyzerComboBox_SelectionChanged"
                              Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding SelectedAnalyzer.Description}" Style="{StaticResource MutedText}" Margin="0,0,0,16"/>

                    <Border Style="{StaticResource ListRow}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Режим выборки" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <CheckBox Content="Только последние снимки объявлений"
                                      IsChecked="{Binding LatestOnly}"
                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                      Margin="0,0,0,8"/>
                            <CheckBox Content="Только объявления с изменениями"
                                      IsChecked="{Binding OnlyChanged}"
                                      Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Если оставить первый пункт включённым, анализатор получит актуальное состояние объявлений без старых снимков." Style="{StaticResource MutedText}" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Фильтры" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Text="Марка" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding Brand, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsTextBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="2">
                            <TextBlock Text="Модель" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding Model, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsTextBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0">
                            <TextBlock Text="Регион продажи" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding SaleRegion, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsTextBox}"/>
                        </StackPanel>

                        <Grid Grid.Row="2" Grid.Column="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Год от" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding YearFromText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Год до" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding YearToText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsTextBox}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <TextBlock Text="Пустые поля фильтров не применяются." Style="{StaticResource MutedText}" Margin="0,8,0,0"/>

                    <Border Style="{StaticResource ListRow}" Margin="0,18,0,0">
                        <StackPanel>
                            <TextBlock Text="Сводка запуска" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SummaryText}" Style="{StaticResource MutedText}" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
