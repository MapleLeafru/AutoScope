<Window x:Class="AutoScope.WpfClient.InputPipelineLaunchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:AutoScope.WpfClient.Models"
        Title="Запуск парсинга" Height="610" Width="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinHeight="560" MinWidth="680"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}">
    <Window.Resources>
        <DataTemplate x:Key="DatabaseComboItemTemplate" DataType="{x:Type models:DatabaseDashboardItem}">
            <StackPanel>
                <TextBlock Text="{Binding Name}"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontWeight="SemiBold"/>
                <TextBlock Text="{Binding ConfigText}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="11"
                           Margin="0,2,0,0"/>
                <TextBlock Text="{Binding FileText}"
                           Foreground="{DynamicResource TextMutedBrush}"
                           FontSize="11"
                           Margin="0,1,0,0"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="ParserComboItemTemplate" DataType="{x:Type models:ParserLaunchItem}">
            <StackPanel>
                <TextBlock Text="{Binding DisplayName}"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontWeight="SemiBold"/>
                <TextBlock Text="{Binding FileName}"
                           Foreground="{DynamicResource TextMutedBrush}"
                           FontSize="11"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Border Margin="18" Style="{StaticResource HubCard}">
        <DockPanel LastChildFill="True">
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                <TextBlock Text="Запуск парсинга" Style="{StaticResource CardTitle}"/>
                <TextBlock Text="Выбери базу, парсер и основные параметры. После запуска процесс появится в блоке процессов после общего обновления хаба." Style="{StaticResource SectionCaption}"/>
            </StackPanel>

            <StackPanel DockPanel.Dock="Bottom" Margin="0,16,0,0">
                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource MutedText}" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Пока доступны основные настройки. Дополнительные параметры берутся из Configs/ParserConfigs." Style="{StaticResource MutedText}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Отмена" Style="{StaticResource BaseButton}" Click="Cancel_Click" Margin="8,0,8,0"/>
                    <Button Grid.Column="2" Content="Запустить" Style="{StaticResource AccentButton}" Click="Start_Click" Margin="0"/>
                </Grid>
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="База данных" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding Databases}"
                              SelectedItem="{Binding SelectedDatabase}"
                              ItemTemplate="{StaticResource DatabaseComboItemTemplate}"
                              Style="{StaticResource SettingsComboBox}"
                              Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding SelectedDatabase.Details}" Style="{StaticResource MutedText}" Margin="0,0,0,16"/>

                    <TextBlock Text="Парсер" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding Parsers}"
                              SelectedItem="{Binding SelectedParser}"
                              ItemTemplate="{StaticResource ParserComboItemTemplate}"
                              Style="{StaticResource SettingsComboBox}"
                              SelectionChanged="ParserComboBox_SelectionChanged"
                              Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding SelectedParser.Description}" Style="{StaticResource MutedText}" Margin="0,0,0,16"/>

                    <TextBlock Text="Стартовый URL" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding StartUrl, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,14"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Максимум объявлений" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding MaxCarsText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsTextBox}"/>
                            <TextBlock Text="0 — собрать все доступные объявления." Style="{StaticResource MutedText}" Margin="0,5,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Размер пакета" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding BatchSizeText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsTextBox}"/>
                            <TextBlock Text="Сколько объявлений передавать в pipeline за один пакет." Style="{StaticResource MutedText}" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Grid>

                    <Border Style="{StaticResource ListRow}" Margin="0,18,0,0">
                        <StackPanel>
                            <TextBlock Text="Сводка запуска" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SummaryText}" Style="{StaticResource MutedText}" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
