<Window x:Class="AutoScope.WpfClient.InputPipelineLaunchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:AutoScope.WpfClient.Models"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Запуск парсинга" Height="760" Width="780"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        MinHeight="650" MinWidth="720"
        Background="Transparent"
        AllowsTransparency="True"
        Foreground="{DynamicResource TextPrimaryBrush}"
        UseLayoutRounding="True">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <DataTemplate x:Key="DatabaseComboItemTemplate" DataType="{x:Type models:DatabaseDashboardItem}">
            <StackPanel>
                <TextBlock Text="{Binding Name}"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontWeight="SemiBold"/>
                <TextBlock Text="{Binding ConfigText}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="11"
                           Margin="0,2,0,0"/>
                <WrapPanel Margin="0,1,0,0">
                    <TextBlock Text="{Binding FileText}"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="11"/>
                    <TextBlock Text=" · "
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="11"/>
                    <TextBlock Text="{Binding SizeText}"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="11"/>
                </WrapPanel>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="ParserComboItemTemplate" DataType="{x:Type models:ParserLaunchItem}">
            <StackPanel>
                <TextBlock Text="{Binding DisplayName}"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontWeight="SemiBold"/>
                <TextBlock Text="{Binding FileName}"
                           Foreground="{DynamicResource TextMutedBrush}"
                           FontSize="11"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

        <Border x:Name="RootWindowBorder"
            Background="{DynamicResource WindowOutlineBrush}"
            CornerRadius="12"
            SnapsToDevicePixels="True">
        <Border Background="{DynamicResource WindowBackgroundBrush}"
                CornerRadius="11"
                Margin="1"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="38"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border x:Name="TitleBar"
                        Grid.Row="0"
                        Background="{DynamicResource TitleBarBackgroundBrush}"
                        BorderBrush="{DynamicResource TitleBarBorderBrush}"
                        BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                        CornerRadius="11,11,0,0">
                    <Grid>
                        <TextBlock Text="Запуск парсинга"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="14,0,0,0"/>
                        <Button HorizontalAlignment="Right"
                                Style="{StaticResource TitleBarCloseButton}"
                                Click="Close_Click"
                                Margin="0,2,6,2"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <Viewbox Width="19" Height="19" Stretch="Uniform">
                                <Canvas Width="18" Height="18">
                                    <Path Stroke="{DynamicResource TextPrimaryBrush}"
                                          StrokeThickness="2.0"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Data="M 4 4 L 14 14 M 14 4 L 4 14"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Margin="18" Style="{StaticResource HubCard}">
        <DockPanel LastChildFill="True">
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                <TextBlock Text="Запуск парсинга" Style="{StaticResource CardTitle}"/>
                <TextBlock Text="Выбери базу, парсер и основные параметры. После запуска процесс появится в блоке процессов после общего обновления хаба." Style="{StaticResource SectionCaption}"/>
            </StackPanel>

            <StackPanel DockPanel.Dock="Bottom" Margin="0,16,0,0">
                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource MutedText}" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Пустые числовые поля используют значения из конфига выбранного парсера." Style="{StaticResource MutedText}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Отмена" Style="{StaticResource BaseButton}" Click="Cancel_Click" Margin="8,0,8,0"/>
                    <Button Grid.Column="2" Content="Запустить" Style="{StaticResource AccentButton}" Click="Start_Click" Margin="0"/>
                </Grid>
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="База данных" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding Databases}"
                              SelectedItem="{Binding SelectedDatabase}"
                              ItemTemplate="{StaticResource DatabaseComboItemTemplate}"
                              Style="{StaticResource SettingsComboBox}"
                              Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding SelectedDatabase.Details}" Style="{StaticResource MutedText}" Margin="0,0,0,16"/>

                    <TextBlock Text="Парсер" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding Parsers}"
                              SelectedItem="{Binding SelectedParser}"
                              ItemTemplate="{StaticResource ParserComboItemTemplate}"
                              Style="{StaticResource SettingsComboBox}"
                              SelectionChanged="ParserComboBox_SelectionChanged"
                              Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding SelectedParser.Description}" Style="{StaticResource MutedText}" Margin="0,0,0,16"/>

                    <TextBlock Text="Стартовый URL" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding StartUrl, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,14"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="MAX_CARS" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding MaxCarsText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsTextBox}"/>
                            <TextBlock Text="0 — собрать все доступные, пусто — из конфига." Style="{StaticResource MutedText}" Margin="0,5,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="STREAM_BATCH_SIZE" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding BatchSizeText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsTextBox}"/>
                            <TextBlock Text="Пустое поле — значение из конфига." Style="{StaticResource MutedText}" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Задержка HTTP, сек." FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding RequestDelaySecondsText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsTextBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Повторы" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding RetryCountText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsTextBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Пауза HTTP 429, сек." FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding RateLimitDelaySecondsText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsTextBox}"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="Для этих полей пустое значение означает настройку из конфига выбранного парсера." Style="{StaticResource MutedText}" Margin="0,5,0,0"/>

                    <Border Style="{StaticResource ListRow}" Margin="0,18,0,0">
                        <StackPanel>
                            <TextBlock Text="Настройки InputApi" FontWeight="SemiBold"/>
                            <TextBlock Text="По умолчанию — использовать значение из конфига. Явный выбор перезапишет его только для этого запуска." Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,4,0,10"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Страна бренда" Style="{StaticResource SectionCaption}"/>
                                    <ComboBox ItemsSource="{Binding BrandCountryOptions}" SelectedItem="{Binding SelectedBrandCountryEnrichment}" DisplayMemberPath="DisplayName" Style="{StaticResource SettingsComboBox}" Margin="0,4,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Коробка передач" Style="{StaticResource SectionCaption}"/>
                                    <ComboBox ItemsSource="{Binding TransmissionOptions}" SelectedItem="{Binding SelectedTransmissionNormalization}" DisplayMemberPath="DisplayName" Style="{StaticResource SettingsComboBox}" Margin="0,4,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Row="2">
                                    <TextBlock Text="Тип привода" Style="{StaticResource SectionCaption}"/>
                                    <ComboBox ItemsSource="{Binding DriveTypeOptions}" SelectedItem="{Binding SelectedDriveTypeNormalization}" DisplayMemberPath="DisplayName" Style="{StaticResource SettingsComboBox}" Margin="0,4,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="2">
                                    <TextBlock Text="Тип топлива" Style="{StaticResource SectionCaption}"/>
                                    <ComboBox ItemsSource="{Binding FuelTypeOptions}" SelectedItem="{Binding SelectedFuelTypeNormalization}" DisplayMemberPath="DisplayName" Style="{StaticResource SettingsComboBox}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ListRow}" Margin="0,18,0,0">
                        <StackPanel>
                            <TextBlock Text="Сводка запуска" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SummaryText}" Style="{StaticResource MutedText}" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
                </Border>
            </Grid>
        </Border>
    </Border>
</Window>
