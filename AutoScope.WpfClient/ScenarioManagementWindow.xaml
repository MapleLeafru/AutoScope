<Window x:Class="AutoScope.WpfClient.ScenarioManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:conv="clr-namespace:AutoScope.WpfClient.Converters"
        Title="Сценарии AutoScope" Height="640" Width="880"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="Transparent"
        AllowsTransparency="True"
        UseLayoutRounding="True">

    <Window.Resources>
        <conv:StatusToBrushConverter x:Key="StatusToBrushConverter"/>
    </Window.Resources>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"/>
    </shell:WindowChrome.WindowChrome>

    <Border x:Name="RootWindowBorder"
            Background="{DynamicResource WindowOutlineBrush}"
            CornerRadius="12"
            SnapsToDevicePixels="True">
        <Border Background="{DynamicResource WindowBackgroundBrush}"
                CornerRadius="11"
                Margin="1"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="38"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border x:Name="TitleBar"
                        Grid.Row="0"
                        Background="{DynamicResource TitleBarBackgroundBrush}"
                        BorderBrush="{DynamicResource TitleBarBorderBrush}"
                        BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                        CornerRadius="11,11,0,0">
                    <Grid>
                        <TextBlock Text="Сценарии AutoScope"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="14,0,0,0"/>
                        <Button HorizontalAlignment="Right"
                                Style="{StaticResource TitleBarCloseButton}"
                                Click="Close_Click"
                                Margin="0,2,6,2"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <Viewbox Width="19" Height="19" Stretch="Uniform">
                                <Canvas Width="18" Height="18">
                                    <Path Stroke="{DynamicResource TextPrimaryBrush}"
                                          StrokeThickness="2.0"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Data="M 4 4 L 14 14 M 14 4 L 4 14"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource HubCard}" Margin="18,18,18,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Управление сценариями" Style="{StaticResource CardTitle}"/>
                            <TextBlock Text="Список строится по JSON-файлам из папки Jobs. Сценарии можно запускать вручную, включать/выключать и базово редактировать без открытия JSON вручную." Style="{StaticResource SectionCaption}"/>
                        </StackPanel>

                        <WrapPanel Grid.Column="1" VerticalAlignment="Top">
                            <Button Content="Создать сценарий" Style="{StaticResource AccentSmallButton}" Click="CreateScenario_Click"/>
                            <Button Content="Обновить" Style="{StaticResource SmallButton}" Click="Refresh_Click"/>
                            <Button Content="Папка" Style="{StaticResource SmallButton}" Click="OpenJobsFolder_Click"/>
                        </WrapPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource HubCard}" Margin="18,0,18,10">
                    <DockPanel LastChildFill="True">
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Найденные сценарии" Style="{StaticResource CardTitle}"/>
                                <TextBlock Text="Включённые сценарии подсвечены зелёным, выключенные — красным, ручные — нейтральным." Style="{StaticResource SectionCaption}"/>
                            </StackPanel>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding ScenarioCountText}"
                                       Foreground="{DynamicResource AccentBrush}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Top"
                                       Margin="12,2,0,0"/>
                        </Grid>

                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Scenarios}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource ListRow}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="10"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Width="6"
                                                        CornerRadius="3"
                                                        Background="{Binding StateKind, Converter={StaticResource StatusToBrushConverter}}"/>

                                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontWeight="SemiBold"
                                                               FontSize="16"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip="{Binding Name}"/>

                                                    <WrapPanel Margin="0,3,0,0">
                                                        <TextBlock Text="{Binding PipelineText}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"/>
                                                        <TextBlock Text=" · " Style="{StaticResource MutedText}"/>
                                                        <TextBlock Text="{Binding StatusText}"
                                                                   Foreground="{Binding StateKind, Converter={StaticResource StatusToBrushConverter}}"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"/>
                                                    </WrapPanel>

                                                    <WrapPanel Margin="0,3,0,0">
                                                        <TextBlock Text="{Binding ScheduleText}" Foreground="{DynamicResource AccentBrush}" FontSize="12" FontWeight="SemiBold"/>
                                                        <TextBlock Text=" · " Style="{StaticResource MutedText}"/>
                                                        <TextBlock Text="{Binding NextRunText}" Foreground="{DynamicResource AccentBrush}" FontSize="12" FontWeight="SemiBold"/>
                                                    </WrapPanel>

                                                    <TextBlock Text="{Binding Details}" Style="{StaticResource MutedText}" Margin="0,4,0,0"/>
                                                    <TextBlock Text="{Binding FileName}" Style="{StaticResource MutedText}" Margin="0,3,0,0"/>

                                                    <WrapPanel Margin="0,12,0,0" HorizontalAlignment="Left">
                                                        <Button Content="Запустить" Style="{StaticResource AccentSmallButton}" Click="RunScenario_Click" Tag="{Binding}" IsEnabled="{Binding CanRun}"/>
                                                        <Button Content="Редактировать" Style="{StaticResource SmallButton}" Click="EditScenario_Click" Tag="{Binding}" IsEnabled="{Binding CanEdit}"/>
                                                        <Button Content="Подробнее" Style="{StaticResource SmallButton}" Click="Details_Click" Tag="{Binding}" IsEnabled="{Binding CanOpenFile}"/>
                                                        <Button Content="{Binding ToggleActionText}" Style="{StaticResource SmallButton}" Click="ToggleScenario_Click" Tag="{Binding}" IsEnabled="{Binding CanOpenFile}"/>
                                                        <Button Content="История" Style="{StaticResource SmallButton}" Click="History_Click" Tag="{Binding}" IsEnabled="{Binding CanShowHistory}"/>
                                                        <Button Content="Файл" Style="{StaticResource SmallButton}" Click="OpenScenarioFile_Click" Tag="{Binding}" IsEnabled="{Binding CanOpenFile}"/>
                                                        <Button Content="Удалить" Style="{StaticResource DangerSmallButton}" Click="DeleteScenario_Click" Tag="{Binding}" IsEnabled="{Binding CanOpenFile}"/>
                                                    </WrapPanel>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <Grid Grid.Row="3" Margin="18,0,18,18">
                    <TextBlock Text="{Binding StatusMessage}"
                               Style="{StaticResource MutedText}"
                               VerticalAlignment="Center"/>
                    <Button Content="Закрыть"
                            Style="{StaticResource BaseButton}"
                            HorizontalAlignment="Right"
                            Click="Close_Click"/>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>
