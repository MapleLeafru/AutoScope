<Window x:Class="AutoScope.WpfClient.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Настройки AutoScope" Height="720" Width="760"
        MinHeight="560" MinWidth="680"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="Transparent"
        AllowsTransparency="True"
        UseLayoutRounding="True">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"/>
    </shell:WindowChrome.WindowChrome>

    <Border x:Name="RootWindowBorder"
            Background="{DynamicResource WindowOutlineBrush}"
            CornerRadius="12"
            SnapsToDevicePixels="True">
        <Border Background="{DynamicResource WindowBackgroundBrush}"
                CornerRadius="11"
                Margin="1"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="38"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border x:Name="TitleBar"
                        Grid.Row="0"
                        Background="{DynamicResource TitleBarBackgroundBrush}"
                        BorderBrush="{DynamicResource TitleBarBorderBrush}"
                        BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                        CornerRadius="11,11,0,0">
                    <Grid>
                        <TextBlock Text="Настройки AutoScope"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="14,0,0,0"/>
                        <Button HorizontalAlignment="Right"
                                Style="{StaticResource TitleBarCloseButton}"
                                Click="Close_Click"
                                Margin="0,2,6,2"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <Viewbox Width="19" Height="19" Stretch="Uniform">
                                <Canvas Width="18" Height="18">
                                    <Path Stroke="{DynamicResource TextPrimaryBrush}"
                                          StrokeThickness="2.0"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Data="M 4 4 L 14 14 M 14 4 L 4 14"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" Margin="18" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Style="{StaticResource HubCard}">
                            <StackPanel>
                                <TextBlock Text="Фоновый режим и автозапуск" Style="{StaticResource CardTitle}"/>
                                <TextBlock Text="Эти параметры управляют тем, будет ли AutoScope продолжать работу в трее и запускаться вместе с Windows для фоновой проверки сценариев."
                                           Style="{StaticResource SectionCaption}"
                                           TextWrapping="Wrap"/>

                                <CheckBox x:Name="RunInBackgroundCheckBox"
                                          Style="{StaticResource SettingsCheckBox}"
                                          Checked="BackgroundSettings_Changed"
                                          Unchecked="BackgroundSettings_Changed">
                                    <TextBlock Text="Разрешить работу в фоновом режиме" TextWrapping="Wrap"/>
                                </CheckBox>
                                <CheckBox x:Name="MinimizeToTrayOnCloseCheckBox"
                                          Style="{StaticResource SettingsCheckBox}">
                                    <TextBlock Text="Сворачивать в трей при закрытии окна" TextWrapping="Wrap"/>
                                </CheckBox>
                                <CheckBox x:Name="ShowBackgroundHintOnCloseCheckBox"
                                          Style="{StaticResource SettingsCheckBox}">
                                    <TextBlock Text="Показывать уведомление, что AutoScope продолжает работать в фоне" TextWrapping="Wrap"/>
                                </CheckBox>

                                <Separator Margin="0,16,0,14"
                                           Background="{DynamicResource CardBorderBrush}"/>

                                <CheckBox x:Name="StartWithWindowsCheckBox"
                                          Style="{StaticResource SettingsCheckBox}"
                                          Checked="StartupSettings_Changed"
                                          Unchecked="StartupSettings_Changed">
                                    <TextBlock Text="Запускать AutoScope вместе с Windows" TextWrapping="Wrap"/>
                                </CheckBox>

                                <TextBlock Text="Способ автозапуска" Style="{StaticResource SecondaryText}" Margin="0,12,0,6"/>
                                <ComboBox x:Name="StartupMethodComboBox"
                                          Style="{StaticResource SettingsComboBox}"
                                          DisplayMemberPath="DisplayName"
                                          SelectionChanged="StartupMethodComboBox_SelectionChanged"/>
                                <TextBlock x:Name="StartupMethodDescriptionText"
                                           Style="{StaticResource MutedText}"
                                           TextWrapping="Wrap"
                                           Margin="0,10,0,0"/>

                                <CheckBox x:Name="StartMinimizedToTrayCheckBox"
                                          Style="{StaticResource SettingsCheckBox}">
                                    <TextBlock Text="При автозапуске открывать сразу в трее" TextWrapping="Wrap"/>
                                </CheckBox>

                                <TextBlock x:Name="StartupStatusText"
                                           Style="{StaticResource MutedText}"
                                           TextWrapping="Wrap"
                                           Margin="0,12,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource HubCard}" Margin="0,14,0,0">
                            <StackPanel>
                                <TextBlock Text="Сценарии и уведомления" Style="{StaticResource CardTitle}"/>
                                <TextBlock Text="Настройки фоновой проверки сценариев. Ручная проверка из главного хаба работает независимо от автопроверки."
                                           Style="{StaticResource SectionCaption}"
                                           TextWrapping="Wrap"/>

                                <CheckBox x:Name="ScenarioAutoCheckEnabledCheckBox"
                                          Style="{StaticResource SettingsCheckBox}">
                                    <TextBlock Text="Включить автопроверку сценариев" TextWrapping="Wrap"/>
                                </CheckBox>

                                <TextBlock Text="Интервал автопроверки" Style="{StaticResource SecondaryText}" Margin="0,12,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="Интервал, мин."
                                               Style="{StaticResource MutedText}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0"/>
                                    <TextBox x:Name="ScenarioAutoCheckIntervalTextBox"
                                             Grid.Column="1"
                                             Style="{StaticResource SettingsTextBox}"
                                             MaxWidth="160"
                                             HorizontalAlignment="Left"/>
                                </Grid>

                                <CheckBox x:Name="ShowScenarioNotificationsCheckBox"
                                          Style="{StaticResource SettingsCheckBox}">
                                    <TextBlock Text="Показывать уведомления при автоматическом запуске сценариев" TextWrapping="Wrap"/>
                                </CheckBox>
                                <CheckBox x:Name="ShowScenarioErrorNotificationsCheckBox"
                                          Style="{StaticResource SettingsCheckBox}">
                                    <TextBlock Text="Показывать уведомления при ошибках автозапуска" TextWrapping="Wrap"/>
                                </CheckBox>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource HubCard}" Margin="0,14,0,0">
                            <StackPanel>
                                <TextBlock Text="Интерфейс" Style="{StaticResource CardTitle}"/>
                                <TextBlock Text="Внешний вид клиента и поведение основных экранов. Новые темы автоматически подхватываются из папки Styles/Themes."
                                           Style="{StaticResource SectionCaption}"
                                           TextWrapping="Wrap"/>

                                <TextBlock Text="Тема приложения" Style="{StaticResource SecondaryText}" Margin="0,8,0,6"/>
                                <ComboBox x:Name="ThemeComboBox"
                                          Style="{StaticResource SettingsComboBox}"
                                          DisplayMemberPath="DisplayName"
                                          SelectionChanged="ThemeComboBox_SelectionChanged"/>

                                <TextBlock x:Name="ThemeDescriptionText"
                                           Style="{StaticResource MutedText}"
                                           TextWrapping="Wrap"
                                           Margin="0,12,0,0"/>

                                <Separator Margin="0,16,0,14"
                                           Background="{DynamicResource CardBorderBrush}"/>

                                <TextBlock Text="Масштаб интерфейса" Style="{StaticResource SecondaryText}" Margin="0,0,0,6"/>
                                <ComboBox x:Name="UiScaleComboBox"
                                          Style="{StaticResource SettingsComboBox}"
                                          DisplayMemberPath="DisplayName"/>
                                <TextBlock Text="Масштаб применяется ко всем открытым окнам после сохранения. Если интерфейс кажется мелким, попробуйте 110% или 125%."
                                           Style="{StaticResource MutedText}"
                                           TextWrapping="Wrap"
                                           Margin="0,10,0,0"/>

                                <CheckBox x:Name="ShowEmptyStateHintsCheckBox"
                                          Style="{StaticResource SettingsCheckBox}">
                                    <TextBlock Text="Показывать подсказки в пустых блоках" TextWrapping="Wrap"/>
                                </CheckBox>
                                <CheckBox x:Name="RememberWindowPlacementCheckBox"
                                          Style="{StaticResource SettingsCheckBox}">
                                    <TextBlock Text="Запоминать положение и размер окна" TextWrapping="Wrap"/>
                                </CheckBox>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource HubCard}" Margin="0,14,0,0">
                            <StackPanel>
                                <TextBlock Text="Внешние инструменты" Style="{StaticResource CardTitle}"/>
                                <TextBlock Text="Здесь можно указать путь к DB Browser for SQLite. Если поле пустое, AutoScope попробует найти программу в папке проекта автоматически."
                                           Style="{StaticResource SectionCaption}"
                                           TextWrapping="Wrap"/>

                                <TextBlock Text="DB Browser for SQLite" Style="{StaticResource SecondaryText}" Margin="0,8,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBox x:Name="DbBrowserPathTextBox"
                                             Grid.Column="0"
                                             Style="{StaticResource SettingsTextBox}"
                                             MinWidth="300"/>
                                    <Button Grid.Column="1"
                                            Content="Выбрать"
                                            Style="{StaticResource SmallButton}"
                                            Margin="8,0,0,0"
                                            Click="BrowseDbBrowser_Click"/>
                                    <Button Grid.Column="2"
                                            Content="Найти"
                                            Style="{StaticResource SmallButton}"
                                            Margin="8,0,0,0"
                                            Click="AutoDetectDbBrowser_Click"/>
                                </Grid>

                                <TextBlock x:Name="DbBrowserHintText"
                                           Style="{StaticResource MutedText}"
                                           TextWrapping="Wrap"
                                           Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource HubCard}" Margin="0,14,0,0">
                            <StackPanel>
                                <TextBlock Text="Процессы и логи" Style="{StaticResource CardTitle}"/>
                                <TextBlock Text="Параметры пока используются как пользовательские предпочтения для дальнейшей полировки поведения процессов и диагностики."
                                           Style="{StaticResource SectionCaption}"
                                           TextWrapping="Wrap"/>

                                <CheckBox x:Name="OpenReportAfterAnalysisCheckBox"
                                          Style="{StaticResource SettingsCheckBox}">
                                    <TextBlock Text="Открывать отчёт после успешного анализа" TextWrapping="Wrap"/>
                                </CheckBox>
                                <CheckBox x:Name="OpenLogOnErrorCheckBox"
                                          Style="{StaticResource SettingsCheckBox}">
                                    <TextBlock Text="Открывать лог при ошибке процесса" TextWrapping="Wrap"/>
                                </CheckBox>

                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="Хранить логи, дней"
                                               Style="{StaticResource MutedText}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0"/>
                                    <TextBox x:Name="KeepLogsDaysTextBox"
                                             Grid.Column="1"
                                             Style="{StaticResource SettingsTextBox}"
                                             MaxWidth="160"
                                             HorizontalAlignment="Left"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource CardBackgroundAltBrush}"
                                BorderBrush="{DynamicResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="12"
                                Margin="0,14,0,0">
                            <TextBlock Style="{StaticResource MutedText}"
                                       TextWrapping="Wrap"
                                       Text="Portable-логика сохраняется: AutoScope не требует установщика, а автозапуск является управляемой системной интеграцией. При выключении автозапуска приложение удаляет и ярлык, и запись в реестре AutoScope."/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="18,0,18,18">
                    <Button Content="Сохранить" Style="{StaticResource AccentButton}" Click="Save_Click"/>
                    <Button Content="Закрыть" Style="{StaticResource BaseButton}" Click="Close_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</Window>
