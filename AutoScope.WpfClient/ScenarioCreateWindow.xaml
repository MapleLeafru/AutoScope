<Window x:Class="AutoScope.WpfClient.ScenarioCreateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Создание сценария" Height="820" Width="820"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="Transparent"
        AllowsTransparency="True"
        UseLayoutRounding="True">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"/>
    </shell:WindowChrome.WindowChrome>

    <Border Background="{DynamicResource WindowOutlineBrush}"
            CornerRadius="12"
            SnapsToDevicePixels="True">
        <Border Background="{DynamicResource WindowBackgroundBrush}"
                CornerRadius="11"
                Margin="1"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="38"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border x:Name="TitleBar"
                        Grid.Row="0"
                        Background="{DynamicResource TitleBarBackgroundBrush}"
                        BorderBrush="{DynamicResource TitleBarBorderBrush}"
                        BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                        CornerRadius="11,11,0,0">
                    <Grid>
                        <TextBlock Text="Создание сценария"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="14,0,0,0"/>
                        <Button HorizontalAlignment="Right"
                                Style="{StaticResource TitleBarCloseButton}"
                                Click="Close_Click"
                                Margin="0,2,6,2"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <Viewbox Width="19" Height="19" Stretch="Uniform">
                                <Canvas Width="18" Height="18">
                                    <Path Stroke="{DynamicResource TextPrimaryBrush}"
                                          StrokeThickness="2.0"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Data="M 4 4 L 14 14 M 14 4 L 4 14"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource HubCard}" Margin="18">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Новый сценарий" Style="{StaticResource CardTitle}"/>
                            <TextBlock Text="Создаётся input/output-сценарий с базовыми параметрами запуска. Позже эту форму можно расширить настройками часов, минут и settingsSchema модулей."
                                       Style="{StaticResource SectionCaption}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,14"/>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="230"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Название сценария" Style="{StaticResource SectionCaption}"/>
                                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource SettingsTextBox}"
                                             Margin="0,4,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Тип сценария" Style="{StaticResource SectionCaption}"/>
                                    <ComboBox ItemsSource="{Binding PipelineOptions}"
                                              SelectedItem="{Binding SelectedPipelineOption}"
                                              Style="{StaticResource SettingsComboBox}"
                                              Margin="0,4,0,0">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="230"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="База данных" Style="{StaticResource SectionCaption}"/>
                                    <ComboBox ItemsSource="{Binding Databases}"
                                              SelectedItem="{Binding SelectedDatabase}"
                                              Style="{StaticResource SettingsComboBox}"
                                              Margin="0,4,0,0">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding LaunchDisplayName}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding FileName}" Foreground="{DynamicResource TextMutedBrush}" FontSize="11"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Расписание" Style="{StaticResource SectionCaption}"/>
                                    <CheckBox Content="Включён"
                                              IsChecked="{Binding Enabled}"
                                              Foreground="{DynamicResource TextPrimaryBrush}"
                                              Margin="0,6,0,4"/>
                                    <CheckBox Content="Только ручной запуск"
                                              IsChecked="{Binding IsManualOnly}"
                                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Интервал автоповтора, часов" Style="{StaticResource SectionCaption}"/>
                            <TextBox Text="{Binding EveryHoursText, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsIntervalEnabled}"
                                     Style="{StaticResource SettingsTextBox}"
                                     FontSize="15"
                                     Margin="0,4,0,16"/>

                            <Border Style="{StaticResource ListRow}" Visibility="{Binding InputSettingsVisibility}">
                                <StackPanel>
                                    <TextBlock Text="Параметры парсинга" FontWeight="SemiBold" FontSize="15"/>
                                    <TextBlock Text="Выбери парсер и базовые настройки запуска." Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,3,0,12"/>

                                    <TextBlock Text="Парсер" Style="{StaticResource SectionCaption}"/>
                                    <ComboBox ItemsSource="{Binding Parsers}"
                                              SelectedItem="{Binding SelectedParser}"
                                              Style="{StaticResource SettingsComboBox}"
                                              DisplayMemberPath="DisplayName"
                                              Margin="0,4,0,8"/>
                                    <TextBlock Text="{Binding SelectedParserDescription}" Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,12"/>

                                    <TextBlock Text="Стартовый URL" Style="{StaticResource SectionCaption}"/>
                                    <TextBox Text="{Binding StartUrl, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource SettingsTextBox}"
                                             Margin="0,4,0,12"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="MAX_CARS" Style="{StaticResource SectionCaption}"/>
                                            <TextBox Text="{Binding MaxCarsText, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource SettingsTextBox}"
                                                     Margin="0,4,0,0"/>
                                            <TextBlock Text="0 — все объявления, пусто — из конфига." Style="{StaticResource MutedText}" Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="STREAM_BATCH_SIZE" Style="{StaticResource SectionCaption}"/>
                                            <TextBox Text="{Binding StreamBatchSizeText, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource SettingsTextBox}"
                                                     Margin="0,4,0,0"/>
                                            <TextBlock Text="Пусто — значение из конфига." Style="{StaticResource MutedText}" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="Задержка HTTP, сек." Style="{StaticResource SectionCaption}"/>
                                            <TextBox Text="{Binding RequestDelaySecondsText, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource SettingsTextBox}"
                                                     Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Повторы" Style="{StaticResource SectionCaption}"/>
                                            <TextBox Text="{Binding RetryCountText, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource SettingsTextBox}"
                                                     Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="4">
                                            <TextBlock Text="Пауза HTTP 429, сек." Style="{StaticResource SectionCaption}"/>
                                            <TextBox Text="{Binding RateLimitDelaySecondsText, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource SettingsTextBox}"
                                                     Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Text="Пустые поля HTTP-настроек используют значения из конфига выбранного парсера." Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,5,0,12"/>

                                    <Border Style="{StaticResource ListRow}" Margin="0,0,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Настройки InputApi" FontWeight="SemiBold"/>
                                            <TextBlock Text="По умолчанию — значение из конфига. Явный выбор сохранится в сценарии." Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,4,0,10"/>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="12"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <StackPanel>
                                                    <TextBlock Text="Страна бренда" Style="{StaticResource SectionCaption}"/>
                                                    <ComboBox ItemsSource="{Binding BrandCountryOptions}" SelectedItem="{Binding SelectedBrandCountryEnrichment}" DisplayMemberPath="DisplayName" Style="{StaticResource SettingsComboBox}" Margin="0,4,0,0"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Коробка передач" Style="{StaticResource SectionCaption}"/>
                                                    <ComboBox ItemsSource="{Binding TransmissionOptions}" SelectedItem="{Binding SelectedTransmissionNormalization}" DisplayMemberPath="DisplayName" Style="{StaticResource SettingsComboBox}" Margin="0,4,0,0"/>
                                                </StackPanel>

                                                <StackPanel Grid.Row="2">
                                                    <TextBlock Text="Тип привода" Style="{StaticResource SectionCaption}"/>
                                                    <ComboBox ItemsSource="{Binding DriveTypeOptions}" SelectedItem="{Binding SelectedDriveTypeNormalization}" DisplayMemberPath="DisplayName" Style="{StaticResource SettingsComboBox}" Margin="0,4,0,0"/>
                                                </StackPanel>

                                                <StackPanel Grid.Row="2" Grid.Column="2">
                                                    <TextBlock Text="Тип топлива" Style="{StaticResource SectionCaption}"/>
                                                    <ComboBox ItemsSource="{Binding FuelTypeOptions}" SelectedItem="{Binding SelectedFuelTypeNormalization}" DisplayMemberPath="DisplayName" Style="{StaticResource SettingsComboBox}" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource ListRow}" Visibility="{Binding OutputSettingsVisibility}">
                                <StackPanel>
                                    <TextBlock Text="Параметры анализа" FontWeight="SemiBold" FontSize="15"/>
                                    <TextBlock Text="Выбери анализатор и базовые фильтры отчёта." Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,3,0,12"/>

                                    <TextBlock Text="Анализатор" Style="{StaticResource SectionCaption}"/>
                                    <ComboBox ItemsSource="{Binding Analyzers}"
                                              SelectedItem="{Binding SelectedAnalyzer}"
                                              Style="{StaticResource SettingsComboBox}"
                                              DisplayMemberPath="DisplayName"
                                              Margin="0,4,0,8"/>
                                    <TextBlock Text="{Binding SelectedAnalyzerDescription}" Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,12"/>

                                    <WrapPanel Margin="0,0,0,12">
                                        <CheckBox Content="Только последние снимки"
                                                  IsChecked="{Binding LatestOnly}"
                                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                                  Margin="0,0,18,0"/>
                                        <CheckBox Content="Только изменённые"
                                                  IsChecked="{Binding OnlyChanged}"
                                                  Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </WrapPanel>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="Марка" Style="{StaticResource SectionCaption}"/>
                                            <TextBox Text="{Binding Brand, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsTextBox}" Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Модель" Style="{StaticResource SectionCaption}"/>
                                            <TextBox Text="{Binding Model, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsTextBox}" Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="4">
                                            <TextBlock Text="Регион" Style="{StaticResource SectionCaption}"/>
                                            <TextBox Text="{Binding SaleRegion, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsTextBox}" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="Год от" Style="{StaticResource SectionCaption}"/>
                                            <TextBox Text="{Binding YearFromText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsTextBox}" Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Год до" Style="{StaticResource SectionCaption}"/>
                                            <TextBox Text="{Binding YearToText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsTextBox}" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource ListRow}" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="Сводка" FontWeight="SemiBold" FontSize="15"/>
                                    <TextBlock Text="{Binding SummaryText}" Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <Grid Grid.Row="2" Margin="18,0,18,18">
                    <TextBlock Text="{Binding StatusMessage}"
                               Style="{StaticResource MutedText}"
                               VerticalAlignment="Center"
                               Margin="0,0,190,0"/>
                    <WrapPanel HorizontalAlignment="Right">
                        <Button Content="Создать" Style="{StaticResource AccentButton}" Click="Create_Click"/>
                        <Button Content="Отмена" Style="{StaticResource BaseButton}" Click="Cancel_Click"/>
                    </WrapPanel>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>
