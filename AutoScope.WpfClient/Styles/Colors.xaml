<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Базовая палитра. Позже сюда можно добавить вторую тему, не переписывая окна. -->
    <Color x:Key="WindowBackgroundColor">#101419</Color>
    <Color x:Key="PanelBackgroundColor">#151A21</Color>
    <Color x:Key="CardBackgroundColor">#1B222B</Color>
    <Color x:Key="CardBackgroundAltColor">#202935</Color>
    <Color x:Key="CardBorderColor">#303A47</Color>

    <Color x:Key="TextPrimaryColor">#F2F5F8</Color>
    <Color x:Key="TextSecondaryColor">#B8C2CF</Color>
    <Color x:Key="TextMutedColor">#7F8A99</Color>

    <Color x:Key="AccentBlueColor">#4C9DFF</Color>
    <Color x:Key="SuccessGreenColor">#42B883</Color>
    <Color x:Key="ErrorRedColor">#E35D6A</Color>
    <Color x:Key="WarningYellowColor">#D9B66A</Color>
    <Color x:Key="NeutralWhiteColor">#E7EAEE</Color>

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource PanelBackgroundColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}"/>
    <SolidColorBrush x:Key="CardBackgroundAltBrush" Color="{StaticResource CardBackgroundAltColor}"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource CardBorderColor}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentBlueColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessGreenColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorRedColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningYellowColor}"/>
    <SolidColorBrush x:Key="NeutralBrush" Color="{StaticResource NeutralWhiteColor}"/>

    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#263241"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#314052"/>
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#394B60"/>
</ResourceDictionary>
