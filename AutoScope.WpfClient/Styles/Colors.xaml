<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--Базовая палитра главного окна. -->
    <Color x:Key="WindowBackgroundColor">#05070A</Color>
    <Color x:Key="PanelBackgroundColor">#0F141A</Color>
    <Color x:Key="CardBackgroundColor">#151B22</Color>
    <Color x:Key="CardBackgroundAltColor">#1C242E</Color>
    <Color x:Key="CardBorderColor">#2B3440</Color>

    <Color x:Key="TextPrimaryColor">#F4F7FA</Color>
    <Color x:Key="TextSecondaryColor">#B8C2CC</Color>
    <Color x:Key="TextMutedColor">#7C8795</Color>

    <Color x:Key="PrimaryAccentColor">#68A7F0</Color>
    <Color x:Key="AccentBlueColor">#68A7F0</Color>
    <Color x:Key="SuccessGreenColor">#46B981</Color>
    <Color x:Key="ErrorRedColor">#E0636B</Color>
    <Color x:Key="WarningYellowColor">#D9B66A</Color>
    <Color x:Key="NeutralWhiteColor">#E7EAEE</Color>

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource PanelBackgroundColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}"/>
    <SolidColorBrush x:Key="CardBackgroundAltBrush" Color="{StaticResource CardBackgroundAltColor}"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource CardBorderColor}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource PrimaryAccentColor}"/>
    <SolidColorBrush x:Key="RunningBrush" Color="{StaticResource AccentBlueColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessGreenColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorRedColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningYellowColor}"/>
    <SolidColorBrush x:Key="NeutralBrush" Color="{StaticResource NeutralWhiteColor}"/>

    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#242A31"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#2E3741"/>
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#394551"/>

    <SolidColorBrush x:Key="AccentButtonBackgroundBrush" Color="#17314F"/>
    <SolidColorBrush x:Key="AccentButtonHoverBrush" Color="#1D4167"/>
    <SolidColorBrush x:Key="AccentButtonPressedBrush" Color="#25517F"/>

    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#10161D"/>
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#344454"/>
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#42566A"/>
    <SolidColorBrush x:Key="ScrollBarThumbPressedBrush" Color="#68A7F0"/>

    <SolidColorBrush x:Key="WindowOutlineBrush" Color="{StaticResource CardBorderColor}"/>

    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#0B1016"/>
    <SolidColorBrush x:Key="TitleBarBorderBrush" Color="#223040"/>
    <SolidColorBrush x:Key="TitleBarButtonHoverBrush" Color="#1B2633"/>
    <SolidColorBrush x:Key="TitleBarButtonPressedBrush" Color="#263647"/>
    <SolidColorBrush x:Key="TitleBarCloseHoverBrush" Color="#B64248"/>
    <SolidColorBrush x:Key="TitleBarClosePressedBrush" Color="#8F3036"/>
</ResourceDictionary>
