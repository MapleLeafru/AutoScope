<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--Базовая палитра главного окна. -->

    <sys:String x:Key="ThemeKey">fiery-red-sunset</sys:String>
    <sys:String x:Key="ThemeDisplayName">Огненно-красный закат</sys:String>
    <sys:String x:Key="ThemeDescription">Драматичная тёмная тема из полуночных, бордовых, алых и золотисто-оранжевых оттенков.</sys:String>
    <Color x:Key="WindowBackgroundColor">#03071E</Color>
    <Color x:Key="PanelBackgroundColor">#160817</Color>
    <Color x:Key="CardBackgroundColor">#240916</Color>
    <Color x:Key="CardBackgroundAltColor">#370617</Color>
    <Color x:Key="CardBorderColor">#6A040F</Color>

    <Color x:Key="TextPrimaryColor">#FFF2E5</Color>
    <Color x:Key="TextSecondaryColor">#FFD7B5</Color>
    <Color x:Key="TextMutedColor">#C98774</Color>

    <Color x:Key="PrimaryAccentColor">#F48C06</Color>
    <Color x:Key="AccentBlueColor">#FAA307</Color>
    <Color x:Key="SuccessGreenColor">#55A630</Color>
    <Color x:Key="ErrorRedColor">#D00000</Color>
    <Color x:Key="WarningYellowColor">#FFBA08</Color>
    <Color x:Key="NeutralWhiteColor">#FFE6B3</Color>

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource PanelBackgroundColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}"/>
    <SolidColorBrush x:Key="CardBackgroundAltBrush" Color="{StaticResource CardBackgroundAltColor}"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource CardBorderColor}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource PrimaryAccentColor}"/>
    <SolidColorBrush x:Key="RunningBrush" Color="{StaticResource AccentBlueColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessGreenColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorRedColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningYellowColor}"/>
    <SolidColorBrush x:Key="NeutralBrush" Color="{StaticResource NeutralWhiteColor}"/>

    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#2D0A16"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#430915"/>
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#5C0713"/>

    <SolidColorBrush x:Key="AccentButtonBackgroundBrush" Color="#5E2205"/>
    <SolidColorBrush x:Key="AccentButtonHoverBrush" Color="#7A2D04"/>
    <SolidColorBrush x:Key="AccentButtonPressedBrush" Color="#9A3903"/>

    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#160817"/>
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#6A040F"/>
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#9D0208"/>
    <SolidColorBrush x:Key="ScrollBarThumbPressedBrush" Color="#F48C06"/>

    <SolidColorBrush x:Key="WindowOutlineBrush" Color="#6A040F"/>

    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#0D0612"/>
    <SolidColorBrush x:Key="TitleBarBorderBrush" Color="#4A0612"/>
    <SolidColorBrush x:Key="TitleBarButtonHoverBrush" Color="#2A0A17"/>
    <SolidColorBrush x:Key="TitleBarButtonPressedBrush" Color="#3F0A17"/>
    <SolidColorBrush x:Key="TitleBarCloseHoverBrush" Color="#9D0208"/>
    <SolidColorBrush x:Key="TitleBarClosePressedBrush" Color="#6A040F"/>
</ResourceDictionary>
