<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--Базовая палитра главного окна. -->

    <sys:String x:Key="ThemeKey">deep-sea-blue</sys:String>
    <sys:String x:Key="ThemeDisplayName">Глубокое морское синее</sys:String>
    <sys:String x:Key="ThemeDescription">Строгая тёмно-синяя тема с переходом от midnight blue к стальным и slate-оттенкам.</sys:String>
    <Color x:Key="WindowBackgroundColor">#001233</Color>
    <Color x:Key="PanelBackgroundColor">#001845</Color>
    <Color x:Key="CardBackgroundColor">#002855</Color>
    <Color x:Key="CardBackgroundAltColor">#023E7D</Color>
    <Color x:Key="CardBorderColor">#33415C</Color>

    <Color x:Key="TextPrimaryColor">#EDF4FF</Color>
    <Color x:Key="TextSecondaryColor">#C7D7EA</Color>
    <Color x:Key="TextMutedColor">#979DAC</Color>

    <Color x:Key="PrimaryAccentColor">#0466C8</Color>
    <Color x:Key="AccentBlueColor">#68A7F0</Color>
    <Color x:Key="SuccessGreenColor">#46B981</Color>
    <Color x:Key="ErrorRedColor">#E0636B</Color>
    <Color x:Key="WarningYellowColor">#F2CC8F</Color>
    <Color x:Key="NeutralWhiteColor">#DDE7F5</Color>

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource PanelBackgroundColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}"/>
    <SolidColorBrush x:Key="CardBackgroundAltBrush" Color="{StaticResource CardBackgroundAltColor}"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource CardBorderColor}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource PrimaryAccentColor}"/>
    <SolidColorBrush x:Key="RunningBrush" Color="{StaticResource AccentBlueColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessGreenColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorRedColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningYellowColor}"/>
    <SolidColorBrush x:Key="NeutralBrush" Color="{StaticResource NeutralWhiteColor}"/>

    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#14213D"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#1D2F50"/>
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#273C62"/>

    <SolidColorBrush x:Key="AccentButtonBackgroundBrush" Color="#02315F"/>
    <SolidColorBrush x:Key="AccentButtonHoverBrush" Color="#03447F"/>
    <SolidColorBrush x:Key="AccentButtonPressedBrush" Color="#0459A4"/>

    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#001845"/>
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#33415C"/>
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#5C677D"/>
    <SolidColorBrush x:Key="ScrollBarThumbPressedBrush" Color="#0466C8"/>

    <SolidColorBrush x:Key="WindowOutlineBrush" Color="#33415C"/>

    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#00152E"/>
    <SolidColorBrush x:Key="TitleBarBorderBrush" Color="#26354F"/>
    <SolidColorBrush x:Key="TitleBarButtonHoverBrush" Color="#10213D"/>
    <SolidColorBrush x:Key="TitleBarButtonPressedBrush" Color="#172C50"/>
    <SolidColorBrush x:Key="TitleBarCloseHoverBrush" Color="#8E353D"/>
    <SolidColorBrush x:Key="TitleBarClosePressedBrush" Color="#692931"/>
</ResourceDictionary>
