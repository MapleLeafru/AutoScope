<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--Базовая палитра главного окна. -->

    <sys:String x:Key="ThemeKey">fresh-greens</sys:String>
    <sys:String x:Key="ThemeDisplayName">Свежая зелень</sys:String>
    <sys:String x:Key="ThemeDescription">Мягкая зелёная тема от мяты до лесного зелёного, адаптированная под тёмный интерфейс.</sys:String>
    <Color x:Key="WindowBackgroundColor">#081C15</Color>
    <Color x:Key="PanelBackgroundColor">#0D2A20</Color>
    <Color x:Key="CardBackgroundColor">#123728</Color>
    <Color x:Key="CardBackgroundAltColor">#1B4332</Color>
    <Color x:Key="CardBorderColor">#2D6A4F</Color>

    <Color x:Key="TextPrimaryColor">#F0FFF4</Color>
    <Color x:Key="TextSecondaryColor">#D8F3DC</Color>
    <Color x:Key="TextMutedColor">#95D5B2</Color>

    <Color x:Key="PrimaryAccentColor">#52B788</Color>
    <Color x:Key="AccentBlueColor">#74C69D</Color>
    <Color x:Key="SuccessGreenColor">#40916C</Color>
    <Color x:Key="ErrorRedColor">#E0636B</Color>
    <Color x:Key="WarningYellowColor">#BFD200</Color>
    <Color x:Key="NeutralWhiteColor">#E6F7EA</Color>

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource PanelBackgroundColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}"/>
    <SolidColorBrush x:Key="CardBackgroundAltBrush" Color="{StaticResource CardBackgroundAltColor}"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource CardBorderColor}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource PrimaryAccentColor}"/>
    <SolidColorBrush x:Key="RunningBrush" Color="{StaticResource AccentBlueColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessGreenColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorRedColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningYellowColor}"/>
    <SolidColorBrush x:Key="NeutralBrush" Color="{StaticResource NeutralWhiteColor}"/>

    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#173B2C"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#204B38"/>
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#2B5D45"/>

    <SolidColorBrush x:Key="AccentButtonBackgroundBrush" Color="#1F5840"/>
    <SolidColorBrush x:Key="AccentButtonHoverBrush" Color="#28704F"/>
    <SolidColorBrush x:Key="AccentButtonPressedBrush" Color="#338960"/>

    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#0D2A20"/>
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#2D6A4F"/>
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#40916C"/>
    <SolidColorBrush x:Key="ScrollBarThumbPressedBrush" Color="#52B788"/>

    <SolidColorBrush x:Key="WindowOutlineBrush" Color="#2D6A4F"/>

    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#0A2119"/>
    <SolidColorBrush x:Key="TitleBarBorderBrush" Color="#245A43"/>
    <SolidColorBrush x:Key="TitleBarButtonHoverBrush" Color="#173B2C"/>
    <SolidColorBrush x:Key="TitleBarButtonPressedBrush" Color="#204B38"/>
    <SolidColorBrush x:Key="TitleBarCloseHoverBrush" Color="#8C3037"/>
    <SolidColorBrush x:Key="TitleBarClosePressedBrush" Color="#68252B"/>
</ResourceDictionary>
