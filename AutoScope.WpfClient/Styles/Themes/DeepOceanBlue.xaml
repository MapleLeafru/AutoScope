<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--Базовая палитра главного окна. -->

    <sys:String x:Key="ThemeKey">deep-ocean-blue</sys:String>
    <sys:String x:Key="ThemeDisplayName">Глубокий океан</sys:String>
    <sys:String x:Key="ThemeDescription">Мрачная океаническая тема с сине-зелёными и тёмно-фиолетовыми слоями.</sys:String>
    <Color x:Key="WindowBackgroundColor">#171429</Color>
    <Color x:Key="PanelBackgroundColor">#1D1933</Color>
    <Color x:Key="CardBackgroundColor">#212F45</Color>
    <Color x:Key="CardBackgroundAltColor">#1B3A4B</Color>
    <Color x:Key="CardBorderColor">#0B525B</Color>

    <Color x:Key="TextPrimaryColor">#EFFBFF</Color>
    <Color x:Key="TextSecondaryColor">#C5DFE3</Color>
    <Color x:Key="TextMutedColor">#88A8B0</Color>

    <Color x:Key="PrimaryAccentColor">#006466</Color>
    <Color x:Key="AccentBlueColor">#0B8E91</Color>
    <Color x:Key="SuccessGreenColor">#57CC99</Color>
    <Color x:Key="ErrorRedColor">#E0636B</Color>
    <Color x:Key="WarningYellowColor">#C9A227</Color>
    <Color x:Key="NeutralWhiteColor">#E3F5F7</Color>

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource PanelBackgroundColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}"/>
    <SolidColorBrush x:Key="CardBackgroundAltBrush" Color="{StaticResource CardBackgroundAltColor}"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource CardBorderColor}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource PrimaryAccentColor}"/>
    <SolidColorBrush x:Key="RunningBrush" Color="{StaticResource AccentBlueColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessGreenColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorRedColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningYellowColor}"/>
    <SolidColorBrush x:Key="NeutralBrush" Color="{StaticResource NeutralWhiteColor}"/>

    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#272640"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#312244"/>
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#3E1F47"/>

    <SolidColorBrush x:Key="AccentButtonBackgroundBrush" Color="#0B3F45"/>
    <SolidColorBrush x:Key="AccentButtonHoverBrush" Color="#0C525A"/>
    <SolidColorBrush x:Key="AccentButtonPressedBrush" Color="#0E666E"/>

    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#1D1933"/>
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#0B525B"/>
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#006466"/>
    <SolidColorBrush x:Key="ScrollBarThumbPressedBrush" Color="#0B8E91"/>

    <SolidColorBrush x:Key="WindowOutlineBrush" Color="#0B525B"/>

    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#171429"/>
    <SolidColorBrush x:Key="TitleBarBorderBrush" Color="#21444F"/>
    <SolidColorBrush x:Key="TitleBarButtonHoverBrush" Color="#272640"/>
    <SolidColorBrush x:Key="TitleBarButtonPressedBrush" Color="#312244"/>
    <SolidColorBrush x:Key="TitleBarCloseHoverBrush" Color="#8E3545"/>
    <SolidColorBrush x:Key="TitleBarClosePressedBrush" Color="#692938"/>
</ResourceDictionary>
