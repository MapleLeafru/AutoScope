<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--Базовая палитра главного окна. -->

    <sys:String x:Key="ThemeKey">light-steel-dark</sys:String>
    <sys:String x:Key="ThemeDisplayName">Светлая сталь — тёмная</sys:String>
    <sys:String x:Key="ThemeDescription">Тёмная стальная интерпретация палитры Light Steel: графитовый фон, холодные серые карточки и чистый голубовато-стальной акцент.</sys:String>
    <Color x:Key="WindowBackgroundColor">#0B0F13</Color>
    <Color x:Key="PanelBackgroundColor">#12171C</Color>
    <Color x:Key="CardBackgroundColor">#1B2127</Color>
    <Color x:Key="CardBackgroundAltColor">#242B32</Color>
    <Color x:Key="CardBorderColor">#495057</Color>

    <Color x:Key="TextPrimaryColor">#F8F9FA</Color>
    <Color x:Key="TextSecondaryColor">#DEE2E6</Color>
    <Color x:Key="TextMutedColor">#ADB5BD</Color>

    <Color x:Key="PrimaryAccentColor">#CED4DA</Color>
    <Color x:Key="AccentBlueColor">#ABC4FF</Color>
    <Color x:Key="SuccessGreenColor">#74C69D</Color>
    <Color x:Key="ErrorRedColor">#E0636B</Color>
    <Color x:Key="WarningYellowColor">#F2CC8F</Color>
    <Color x:Key="NeutralWhiteColor">#E9ECEF</Color>

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource PanelBackgroundColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}"/>
    <SolidColorBrush x:Key="CardBackgroundAltBrush" Color="{StaticResource CardBackgroundAltColor}"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource CardBorderColor}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource PrimaryAccentColor}"/>
    <SolidColorBrush x:Key="RunningBrush" Color="{StaticResource AccentBlueColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessGreenColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorRedColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningYellowColor}"/>
    <SolidColorBrush x:Key="NeutralBrush" Color="{StaticResource NeutralWhiteColor}"/>

    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#212529"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#2B3239"/>
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#343A40"/>

    <SolidColorBrush x:Key="AccentButtonBackgroundBrush" Color="#273544"/>
    <SolidColorBrush x:Key="AccentButtonHoverBrush" Color="#33475A"/>
    <SolidColorBrush x:Key="AccentButtonPressedBrush" Color="#40566B"/>

    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#11161B"/>
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#495057"/>
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#6C757D"/>
    <SolidColorBrush x:Key="ScrollBarThumbPressedBrush" Color="#CED4DA"/>

    <SolidColorBrush x:Key="WindowOutlineBrush" Color="#495057"/>

    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#0D1217"/>
    <SolidColorBrush x:Key="TitleBarBorderBrush" Color="#343A40"/>
    <SolidColorBrush x:Key="TitleBarButtonHoverBrush" Color="#202830"/>
    <SolidColorBrush x:Key="TitleBarButtonPressedBrush" Color="#303A44"/>
    <SolidColorBrush x:Key="TitleBarCloseHoverBrush" Color="#7B3138"/>
    <SolidColorBrush x:Key="TitleBarClosePressedBrush" Color="#62262C"/>
</ResourceDictionary>
