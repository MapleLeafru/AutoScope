<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--Базовая палитра главного окна. -->

    <sys:String x:Key="ThemeKey">blue-serenity</sys:String>
    <sys:String x:Key="ThemeDisplayName">Голубая безмятежность</sys:String>
    <sys:String x:Key="ThemeDescription">Спокойная тема Blue Serenity с туманными голубыми, лавандовыми и pale indigo оттенками на затемнённой основе.</sys:String>
    <Color x:Key="WindowBackgroundColor">#0E1424</Color>
    <Color x:Key="PanelBackgroundColor">#141C31</Color>
    <Color x:Key="CardBackgroundColor">#1A2440</Color>
    <Color x:Key="CardBackgroundAltColor">#223052</Color>
    <Color x:Key="CardBorderColor">#4F6390</Color>

    <Color x:Key="TextPrimaryColor">#F5F8FF</Color>
    <Color x:Key="TextSecondaryColor">#D7E3FC</Color>
    <Color x:Key="TextMutedColor">#A8B6D8</Color>

    <Color x:Key="PrimaryAccentColor">#ABC4FF</Color>
    <Color x:Key="AccentBlueColor">#B6CCFE</Color>
    <Color x:Key="SuccessGreenColor">#95D5B2</Color>
    <Color x:Key="ErrorRedColor">#E0636B</Color>
    <Color x:Key="WarningYellowColor">#F2CC8F</Color>
    <Color x:Key="NeutralWhiteColor">#EDF2FB</Color>

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource PanelBackgroundColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}"/>
    <SolidColorBrush x:Key="CardBackgroundAltBrush" Color="{StaticResource CardBackgroundAltColor}"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource CardBorderColor}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource PrimaryAccentColor}"/>
    <SolidColorBrush x:Key="RunningBrush" Color="{StaticResource AccentBlueColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessGreenColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorRedColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningYellowColor}"/>
    <SolidColorBrush x:Key="NeutralBrush" Color="{StaticResource NeutralWhiteColor}"/>

    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#222D4B"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#2C3A60"/>
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#364775"/>

    <SolidColorBrush x:Key="AccentButtonBackgroundBrush" Color="#304A78"/>
    <SolidColorBrush x:Key="AccentButtonHoverBrush" Color="#3A5C93"/>
    <SolidColorBrush x:Key="AccentButtonPressedBrush" Color="#456FAE"/>

    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#141C31"/>
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#4F6390"/>
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#6E86B8"/>
    <SolidColorBrush x:Key="ScrollBarThumbPressedBrush" Color="#ABC4FF"/>

    <SolidColorBrush x:Key="WindowOutlineBrush" Color="#4F6390"/>

    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#101829"/>
    <SolidColorBrush x:Key="TitleBarBorderBrush" Color="#3B4F7A"/>
    <SolidColorBrush x:Key="TitleBarButtonHoverBrush" Color="#222D4B"/>
    <SolidColorBrush x:Key="TitleBarButtonPressedBrush" Color="#2C3A60"/>
    <SolidColorBrush x:Key="TitleBarCloseHoverBrush" Color="#8E3545"/>
    <SolidColorBrush x:Key="TitleBarClosePressedBrush" Color="#692938"/>
</ResourceDictionary>
