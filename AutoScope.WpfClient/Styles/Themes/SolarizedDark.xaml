<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--Базовая палитра главного окна. -->

    <sys:String x:Key="ThemeKey">solarized-dark</sys:String>
    <sys:String x:Key="ThemeDisplayName">Solarized Dark</sys:String>
    <sys:String x:Key="ThemeDescription">Тёмная схема AutoScope на официальной 16-цветной палитре Solarized.</sys:String>
    <Color x:Key="WindowBackgroundColor">#002b36</Color>
    <Color x:Key="PanelBackgroundColor">#073642</Color>
    <Color x:Key="CardBackgroundColor">#073642</Color>
    <Color x:Key="CardBackgroundAltColor">#586e75</Color>
    <Color x:Key="CardBorderColor">#657b83</Color>

    <Color x:Key="TextPrimaryColor">#93a1a1</Color>
    <Color x:Key="TextSecondaryColor">#839496</Color>
    <Color x:Key="TextMutedColor">#586e75</Color>

    <Color x:Key="PrimaryAccentColor">#268bd2</Color>
    <Color x:Key="AccentBlueColor">#268bd2</Color>
    <Color x:Key="SuccessGreenColor">#859900</Color>
    <Color x:Key="ErrorRedColor">#dc322f</Color>
    <Color x:Key="WarningYellowColor">#b58900</Color>
    <Color x:Key="NeutralWhiteColor">#eee8d5</Color>

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource PanelBackgroundColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}"/>
    <SolidColorBrush x:Key="CardBackgroundAltBrush" Color="{StaticResource CardBackgroundAltColor}"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource CardBorderColor}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource PrimaryAccentColor}"/>
    <SolidColorBrush x:Key="RunningBrush" Color="{StaticResource AccentBlueColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessGreenColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorRedColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningYellowColor}"/>
    <SolidColorBrush x:Key="NeutralBrush" Color="{StaticResource NeutralWhiteColor}"/>

    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#073642"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#586e75"/>
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#657b83"/>

    <SolidColorBrush x:Key="AccentButtonBackgroundBrush" Color="#268bd2"/>
    <SolidColorBrush x:Key="AccentButtonHoverBrush" Color="#2aa198"/>
    <SolidColorBrush x:Key="AccentButtonPressedBrush" Color="#6c71c4"/>

    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#002b36"/>
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#586e75"/>
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#657b83"/>
    <SolidColorBrush x:Key="ScrollBarThumbPressedBrush" Color="#268bd2"/>

    <SolidColorBrush x:Key="WindowOutlineBrush" Color="{StaticResource CardBorderColor}"/>

    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#002b36"/>
    <SolidColorBrush x:Key="TitleBarBorderBrush" Color="#073642"/>
    <SolidColorBrush x:Key="TitleBarButtonHoverBrush" Color="#073642"/>
    <SolidColorBrush x:Key="TitleBarButtonPressedBrush" Color="#586e75"/>
    <SolidColorBrush x:Key="TitleBarCloseHoverBrush" Color="#dc322f"/>
    <SolidColorBrush x:Key="TitleBarClosePressedBrush" Color="#cb4b16"/>
</ResourceDictionary>
