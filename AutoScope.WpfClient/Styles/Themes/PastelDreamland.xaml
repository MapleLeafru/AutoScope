<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--Базовая палитра главного окна. -->

    <sys:String x:Key="ThemeKey">pastel-dreamland</sys:String>
    <sys:String x:Key="ThemeDisplayName">Пастельная страна грёз</sys:String>
    <sys:String x:Key="ThemeDescription">Мягкая сказочная тема с фиолетовыми, розовыми и голубыми оттенками. Тёмная основа сохранена для читаемости интерфейса.</sys:String>
    <Color x:Key="WindowBackgroundColor">#16121D</Color>
    <Color x:Key="PanelBackgroundColor">#211A2A</Color>
    <Color x:Key="CardBackgroundColor">#2B2335</Color>
    <Color x:Key="CardBackgroundAltColor">#372D43</Color>
    <Color x:Key="CardBorderColor">#5B4A68</Color>

    <Color x:Key="TextPrimaryColor">#FFF7FC</Color>
    <Color x:Key="TextSecondaryColor">#EADDF3</Color>
    <Color x:Key="TextMutedColor">#BFA9CB</Color>

    <Color x:Key="PrimaryAccentColor">#FFAFCC</Color>
    <Color x:Key="AccentBlueColor">#A2D2FF</Color>
    <Color x:Key="SuccessGreenColor">#B7E4C7</Color>
    <Color x:Key="ErrorRedColor">#FF8EA8</Color>
    <Color x:Key="WarningYellowColor">#FFC8DD</Color>
    <Color x:Key="NeutralWhiteColor">#F5E8FF</Color>

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource PanelBackgroundColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}"/>
    <SolidColorBrush x:Key="CardBackgroundAltBrush" Color="{StaticResource CardBackgroundAltColor}"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource CardBorderColor}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource PrimaryAccentColor}"/>
    <SolidColorBrush x:Key="RunningBrush" Color="{StaticResource AccentBlueColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessGreenColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorRedColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningYellowColor}"/>
    <SolidColorBrush x:Key="NeutralBrush" Color="{StaticResource NeutralWhiteColor}"/>

    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#34293F"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#42324F"/>
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#4E3A5E"/>

    <SolidColorBrush x:Key="AccentButtonBackgroundBrush" Color="#53324A"/>
    <SolidColorBrush x:Key="AccentButtonHoverBrush" Color="#6A3F5C"/>
    <SolidColorBrush x:Key="AccentButtonPressedBrush" Color="#814C6F"/>

    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#211A2A"/>
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#6D5A7A"/>
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#8D77A0"/>
    <SolidColorBrush x:Key="ScrollBarThumbPressedBrush" Color="#FFAFCC"/>

    <SolidColorBrush x:Key="WindowOutlineBrush" Color="#5B4A68"/>

    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#1B1524"/>
    <SolidColorBrush x:Key="TitleBarBorderBrush" Color="#4B3D58"/>
    <SolidColorBrush x:Key="TitleBarButtonHoverBrush" Color="#322640"/>
    <SolidColorBrush x:Key="TitleBarButtonPressedBrush" Color="#443351"/>
    <SolidColorBrush x:Key="TitleBarCloseHoverBrush" Color="#A84A64"/>
    <SolidColorBrush x:Key="TitleBarClosePressedBrush" Color="#7E354B"/>
</ResourceDictionary>
