<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--Базовая палитра главного окна. -->

    <sys:String x:Key="ThemeKey">fiery-orange-gradient</sys:String>
    <sys:String x:Key="ThemeDisplayName">Огненный оранжевый градиент</sys:String>
    <sys:String x:Key="ThemeDescription">Горячая тема с оранжевым акцентом от красного пламени до медового золота.</sys:String>
    <Color x:Key="WindowBackgroundColor">#160700</Color>
    <Color x:Key="PanelBackgroundColor">#220B00</Color>
    <Color x:Key="CardBackgroundColor">#301000</Color>
    <Color x:Key="CardBackgroundAltColor">#421600</Color>
    <Color x:Key="CardBorderColor">#8A3100</Color>

    <Color x:Key="TextPrimaryColor">#FFF4E6</Color>
    <Color x:Key="TextSecondaryColor">#FFD8A8</Color>
    <Color x:Key="TextMutedColor">#C9905F</Color>

    <Color x:Key="PrimaryAccentColor">#FF9100</Color>
    <Color x:Key="AccentBlueColor">#FFB600</Color>
    <Color x:Key="SuccessGreenColor">#80B918</Color>
    <Color x:Key="ErrorRedColor">#D00000</Color>
    <Color x:Key="WarningYellowColor">#FFAA00</Color>
    <Color x:Key="NeutralWhiteColor">#FFE0B2</Color>

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource PanelBackgroundColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}"/>
    <SolidColorBrush x:Key="CardBackgroundAltBrush" Color="{StaticResource CardBackgroundAltColor}"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource CardBorderColor}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource PrimaryAccentColor}"/>
    <SolidColorBrush x:Key="RunningBrush" Color="{StaticResource AccentBlueColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessGreenColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorRedColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningYellowColor}"/>
    <SolidColorBrush x:Key="NeutralBrush" Color="{StaticResource NeutralWhiteColor}"/>

    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#3A1300"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#501B00"/>
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#662200"/>

    <SolidColorBrush x:Key="AccentButtonBackgroundBrush" Color="#612200"/>
    <SolidColorBrush x:Key="AccentButtonHoverBrush" Color="#7A2C00"/>
    <SolidColorBrush x:Key="AccentButtonPressedBrush" Color="#943500"/>

    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#220B00"/>
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#8A3100"/>
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#B84600"/>
    <SolidColorBrush x:Key="ScrollBarThumbPressedBrush" Color="#FF9100"/>

    <SolidColorBrush x:Key="WindowOutlineBrush" Color="#8A3100"/>

    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#1B0900"/>
    <SolidColorBrush x:Key="TitleBarBorderBrush" Color="#6A2400"/>
    <SolidColorBrush x:Key="TitleBarButtonHoverBrush" Color="#3A1300"/>
    <SolidColorBrush x:Key="TitleBarButtonPressedBrush" Color="#501B00"/>
    <SolidColorBrush x:Key="TitleBarCloseHoverBrush" Color="#A03300"/>
    <SolidColorBrush x:Key="TitleBarClosePressedBrush" Color="#7A2600"/>
</ResourceDictionary>
